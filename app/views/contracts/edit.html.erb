<div class="max-w-lg mx-auto space-y-6 py-4">
  <header class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0">
      <h1 class="text-xl font-semibold text-primary"><%= t(".title") %></h1>
      <p class="text-sm text-secondary mt-1 truncate"><%= @contract.name %></p>
    </div>
    <%= render DS::Button.new(
      text: t(".delete"),
      href: contract_path(@contract),
      method: :delete,
      variant: :outline_destructive,
      icon: "trash-2",
      confirm: CustomConfirm.for_resource_deletion(@contract.name)
    ) %>
  </header>

  <%= render "form", contract: @contract %>
</div>
