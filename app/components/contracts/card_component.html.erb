<%= link_to edit_contract_path(contract),
      class: "block bg-container rounded-xl shadow-border-xs p-4 hover:shadow-border-sm transition-shadow" do %>
  <div class="flex items-start justify-between gap-2">
    <div class="flex items-center gap-2 min-w-0">
      <span class="text-secondary shrink-0"><%= helpers.icon("file-text") %></span>
      <p class="text-sm font-medium text-primary truncate"><%= contract.name %></p>
    </div>
    <p class="text-sm font-medium text-primary tabular-nums shrink-0 privacy-sensitive"><%= amount_label %></p>
  </div>

  <div class="mt-3 flex items-center justify-between gap-2">
    <div class="flex items-center gap-2 min-w-0">
      <% if category_label.present? %>
        <%= render DS::Pill.new(label: category_label, tone: :gray, marker: false) %>
      <% end %>
      <% if overdue? %>
        <%= render DS::Pill.new(label: overdue_label, tone: :warning, marker: false) %>
      <% end %>
    </div>
    <% if next_due_label.present? && !overdue? %>
      <p class="text-xs text-secondary shrink-0"><%= t("contracts.card.next_due", date: next_due_label) %></p>
    <% end %>
  </div>
<% end %>
