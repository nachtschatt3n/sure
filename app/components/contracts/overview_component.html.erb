<div class="space-y-8">
  <section class="grid grid-cols-1 @3xl:grid-cols-2 gap-3">
    <div class="bg-container rounded-xl shadow-border-xs px-5 py-5">
      <p class="text-[11px] font-medium uppercase tracking-wide text-secondary"><%= t("contracts.overview.monthly_total_label") %></p>
      <p class="text-3xl font-medium text-primary tabular-nums mt-2 privacy-sensitive"><%= monthly_total.format %></p>
      <p class="text-xs text-secondary mt-1"><%= t("contracts.overview.monthly_total_sub") %></p>
    </div>

    <div class="bg-container rounded-xl shadow-border-xs px-5 py-5">
      <p class="text-[11px] font-medium uppercase tracking-wide text-secondary"><%= t("contracts.overview.total_count_label") %></p>
      <p class="text-3xl font-medium text-primary tabular-nums mt-2"><%= total_count %></p>
      <p class="text-xs text-secondary mt-1"><%= t("contracts.overview.total_count_sub", count: clusters.size) %></p>
    </div>
  </section>

  <% clusters.each do |cluster| %>
    <%= render Contracts::ClusterComponent.new(cluster: cluster) %>
  <% end %>
</div>
